# Frontend configuration — copy to app/.env (gitignored).
# NEVER put secrets here: every VITE_* value is inlined into the public
# browser bundle. Secrets belong in server/.env only.

# Provider mode: "mock" (simulated demo data) or "composio" (real accounts
# via the server-side API boundary). Anything else falls back to "mock"
# at startup; there is no runtime fallback between modes.
VITE_SOCIAL_PROVIDER_MODE=mock
