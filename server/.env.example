# Server-side secrets and configuration — copy to server/.env (gitignored).
# Never expose these to the browser or commit real values.

# Composio workspace API key (secret).
COMPOSIO_API_KEY=

# Composio tool slug for the verified Instagram identity read (non-secret
# selector, e.g. the tool used in the external verification run).
COMPOSIO_INSTAGRAM_IDENTITY_TOOL=

# Port for the local API boundary.
PORT=8787
